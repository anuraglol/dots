[Unit]
Description=Disable XHC USB wakeup sources to prevent spurious resume/re-suspend loop
After=multi-user.target

[Service]
Type=oneshot
ExecStart=/bin/bash -c 'for dev in XHC0 XHC1 XHC2 XHC3 XHC4; do grep -q "^$${dev}.*enabled" /proc/acpi/wakeup && echo "$$dev" > /proc/acpi/wakeup; done'
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
